# =============================================================================
# Workspace — Development Environment
# =============================================================================
# Copy this file to .env and uncomment/edit the values you need.
# All variables are optional — the app works out of the box without any .env.
# =============================================================================

# --- Core -------------------------------------------------------------------
# DEBUG=True                          # Enabled by default
# SECRET_KEY=                         # Auto-generated insecure key used in dev

# --- Database ----------------------------------------------------------------
# SQLite (default) — no config needed
# PostgreSQL example:
# DATABASE_URL=postgres://user:password@localhost:5432/workspace

# --- Redis (optional) -------------------------------------------------------
# Enables caching, session storage, and Celery background workers.
# Without Redis, cache is in-memory and Celery tasks run synchronously.
# REDIS_URL=redis://localhost:6379

# --- AI (optional) ----------------------------------------------------------
# AI_API_KEY=sk-...                   # OpenAI or compatible provider API key
# AI_BASE_URL=http://localhost:11434/v1  # Ollama / LM Studio endpoint
# AI_MODEL=gpt-5                      # Default model for chat and tools
# AI_SMALL_MODEL=                     # Fast model for summaries and titles
# AI_EXTRACT_MODEL=                   # Model for mail event extraction (defaults to AI_MODEL)
# AI_MAX_TOKENS=2048
# AI_TIMEOUT=300                      # Seconds per AI request
# AI_IMAGE_MODEL=dall-e-3             # Image generation model
# AI_IMAGE_BASE_URL=                  # Separate endpoint for image generation

# --- Web Search (optional) --------------------------------------------------
# Requires a running SearXNG instance (see docker-compose for setup)
# SEARXNG_URL=http://localhost:8080

# --- OAuth2 Mail Providers (optional) ---------------------------------------
# Google (Gmail / Google Workspace)
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=

# Microsoft (Outlook / Office 365)
# OAUTH_MICROSOFT_CLIENT_ID=
# OAUTH_MICROSOFT_CLIENT_SECRET=

# --- OIDC Login / SSO (optional) --------------------------------------------
# Let users sign in with an external identity provider (Keycloak, Authentik,
# Authelia, Google Workspace, Azure AD...) next to the local login form. It is
# enabled only when the client id/secret and the OP endpoints below are all set;
# the local username/password login keeps working either way.
# Tip: run `python manage.py oidc_discover https://<issuer>` to print the four
# OIDC_OP_* endpoints. Register {your-origin}/oidc/callback/ as the redirect URI.
# First login auto-creates the account; the provider then owns the display name
# (synced on each login) and the local password change is disabled for it.
# OIDC_RP_CLIENT_ID=
# OIDC_RP_CLIENT_SECRET=
# OIDC_OP_AUTHORIZATION_ENDPOINT=
# OIDC_OP_TOKEN_ENDPOINT=
# OIDC_OP_USER_ENDPOINT=
# OIDC_OP_JWKS_ENDPOINT=
# OIDC_PROVIDER_NAME=OpenID                # Label shown on the login button
# OIDC_RP_SIGN_ALGO=RS256                  # ID token signing algorithm
# OIDC_RP_SCOPES=openid email profile      # 'profile' is needed for the name
# OIDC_ALLOWED_DOMAINS=                     # Comma-separated email-domain allowlist
# OIDC_REQUIRE_EMAIL_VERIFIED=false        # Require the email_verified claim
# OIDC_USERNAME_CLAIM=preferred_username   # Claim used for the Django username

# --- Web Push Notifications (optional) --------------------------------------
# Generate VAPID keys: python -c "from pywebpush import webpush; from cryptography.hazmat.primitives.asymmetric import ec; ..."
# WEBPUSH_VAPID_PRIVATE_KEY=
# WEBPUSH_VAPID_PUBLIC_KEY=
# WEBPUSH_VAPID_MAILTO=mailto:admin@example.com
